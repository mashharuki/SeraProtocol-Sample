### ============================================================
### SeraProtocol MCP Server - HTTP Test Requests
### ============================================================
###
### Usage:
###   1. Start server: TRANSPORT=http node dist/index.js
###      or:           npm run start:http
###   2. Run requests in order (Initialize -> tools)
###
### Requires VS Code REST Client extension or IntelliJ HTTP Client
### ============================================================

@session_id = ae032fbc-317d-47aa-a2f1-8b771d2014a0

### ──────────────────────────────────────────────
### Health Check
### ──────────────────────────────────────────────

GET http://localhost:3000/health
Accept: application/json

### ──────────────────────────────────────────────
### 1. Initialize Session (MUST run first)
###    Copy the mcp-session-id from the response header
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 0,
  "method": "initialize",
  "params": {
    "capabilities": {},
    "clientInfo": {
      "name": "http-test-client",
      "version": "0.1"
    },
    "protocolVersion": "2024-11-05"
  }
}

### ──────────────────────────────────────────────
### 2. List Tools
###    Replace {{session_id}} with the mcp-session-id
###    from the Initialize response header
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "tools/list"
}

### ──────────────────────────────────────────────
### 3. sera_get_market - Get Market Info
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "sera_get_market",
    "arguments": {
      "market_id": "0x002930b390ac7d686f07cffb9d7ce39609d082d1"
    }
  }
}

### ──────────────────────────────────────────────
### 4. sera_list_markets - List Markets
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "sera_list_markets",
    "arguments": {
      "limit": 5
    }
  }
}

### ──────────────────────────────────────────────
### 5. sera_get_orderbook - Get Order Book
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "sera_get_orderbook",
    "arguments": {
      "market_id": "0x002930b390ac7d686f07cffb9d7ce39609d082d1",
      "depth": 5
    }
  }
}

### ──────────────────────────────────────────────
### 6. sera_get_orders - Get User Orders
###    Replace the user_address with your wallet
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "tools/call",
  "params": {
    "name": "sera_get_orders",
    "arguments": {
      "user_address": "0xda6e605db8c3221f4b3706c1da9c4e28195045f5",
      "market_id": "0x002930b390ac7d686f07cffb9d7ce39609d082d1",
      "limit": 10
    }
  }
}

### ──────────────────────────────────────────────
### 7. sera_get_token_balance - Check Token Balance
###    Replace token_address and account_address
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 6,
  "method": "tools/call",
  "params": {
    "name": "sera_get_token_balance",
    "arguments": {
      "token_address": "0x03a8d551bf1d708471064aa97fea004a45ed8cf3",
      "account_address": "0xda6e605db8c3221f4b3706c1da9c4e28195045f5"
    }
  }
}

### ──────────────────────────────────────────────
### 8. sera_approve_token - Approve Token
###    (Requires PRIVATE_KEY env var)
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 7,
  "method": "tools/call",
  "params": {
    "name": "sera_approve_token",
    "arguments": {
      "token_address": "0x03a8d551bf1d708471064aa97fea004a45ed8cf3",
      "amount": "115792089237316195423570985008687907853269984665640564039457584007913129639935"
    }
  }
}

### ──────────────────────────────────────────────
### 9. sera_place_order - Place Limit Order
###    (Requires PRIVATE_KEY env var)
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 8,
  "method": "tools/call",
  "params": {
    "name": "sera_place_order",
    "arguments": {
      "market_id": "0x002930b390ac7d686f07cffb9d7ce39609d082d1",
      "price_index": 100,
      "raw_amount": "1000000",
      "is_bid": true,
      "post_only": true
    }
  }
}

### ──────────────────────────────────────────────
### 10. sera_claim_order - Claim Filled Order
###     (Requires PRIVATE_KEY env var)
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 9,
  "method": "tools/call",
  "params": {
    "name": "sera_claim_order",
    "arguments": {
      "market_id": "0x002930b390ac7d686f07cffb9d7ce39609d082d1",
      "is_bid": true,
      "price_index": 100,
      "order_index": "0"
    }
  }
}

### ──────────────────────────────────────────────
### 11. Error: Invalid market address
### ──────────────────────────────────────────────

POST http://localhost:3000/mcp
Content-Type: application/json
Accept: application/json, text/event-stream
mcp-session-id: {{session_id}}

{
  "jsonrpc": "2.0",
  "id": 10,
  "method": "tools/call",
  "params": {
    "name": "sera_get_market",
    "arguments": {
      "market_id": "0x0000000000000000000000000000000000000000"
    }
  }
}

### ──────────────────────────────────────────────
### 12. Close Session
### ──────────────────────────────────────────────

DELETE http://localhost:3000/mcp
mcp-session-id: {{session_id}}
