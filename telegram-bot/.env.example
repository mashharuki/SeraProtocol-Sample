# --- Telegram ---
TELEGRAM_BOT_TOKEN=                # from @BotFather
TELEGRAM_WEBHOOK_SECRET=           # random string; required in webhook mode
BOT_MODE=polling                   # polling (local dev) | webhook (Cloud Run)
PUBLIC_URL=                        # webhook mode: https://<service>.run.app
PORT=3000

# --- AI agent (optional; free-text chat is disabled without it) ---
ANTHROPIC_API_KEY=

# --- Privy server wallets ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Database (LibSQL) ---
DATABASE_URL=file:./data/bot.db    # prod: libsql://<db-name>.turso.io
DATABASE_AUTH_TOKEN=               # required for Turso

# --- Networks ---
DEFAULT_NETWORK=sepolia
RPC_URL_MAINNET=https://eth.drpc.org
RPC_URL_SEPOLIA=https://0xrpc.io/sep
SERA_API_URL_MAINNET=https://api.sera.cx/api/v1
SERA_API_URL_SEPOLIA=https://api-testnet.sera.cx/api/v1

# --- GCP deploy (scripts/deploy.sh; 省略時は gcloud config の値を使用) ---
GCP_PROJECT_ID=
