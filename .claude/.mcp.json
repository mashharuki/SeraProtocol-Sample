{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server"
      ]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "sera": {
      "command": "node",
      "args": ["/Users/harukikondo/git/SeraProtocol-Sample/sera-mcp/dist/index.js"],
      "env": {
        "SERA_NETWORK": "testnet",
        "POLICY_PRESET": "standard"
      }
    }
  }
}